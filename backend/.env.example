# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_INITDB_ARGS=--encoding=UTF8

# Service Names (used in connection strings)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
KAFKA_HOST=kafka
KAFKA_PORT=9092
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
SEQ_HOST=seq
SEQ_PORT=5341

# JWT Configuration (used by services)
JWT_SECRET=your-super-secret-key-change-this-in-production-at-least-32-chars
JWT_ISSUER=hr-analytics-platform
JWT_AUDIENCE=hr-analytics-platform
JWT_EXPIRATION_MINUTES=60

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Logging
SERILOG_MINIMUM_LEVEL=Information
SEQ_API_KEY=

# Database Names
IDENTITY_DB=hr_identity
EMPLOYEE_DB=hr_employee
PERFORMANCE_DB=hr_performance
ATTENDANCE_DB=hr_attendance
PAYROLL_DB=hr_payroll
ANALYTICS_DB=hr_analytics

# Service Ports
API_GATEWAY_PORT=5000
IDENTITY_SERVICE_PORT=5001
EMPLOYEE_SERVICE_PORT=5002
PERFORMANCE_SERVICE_PORT=5003
ATTENDANCE_SERVICE_PORT=5005
PAYROLL_SERVICE_PORT=5006
ANALYTICS_SERVICE_PORT=5007
NOTIFICATION_SERVICE_PORT=5008
AUDIT_SERVICE_PORT=5009

# Feature Flags
ENABLE_KAFKA=true
ENABLE_ELASTICSEARCH=true
ENABLE_ANALYTICS=false
ENABLE_NOTIFICATIONS=false
