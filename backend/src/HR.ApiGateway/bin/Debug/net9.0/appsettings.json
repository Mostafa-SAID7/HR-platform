{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "Gateway": {
    "Port": 5000,
    "ServiceEndpoints": {
      "IdentityService": "http://localhost:5001",
      "EmployeeService": "http://localhost:5002",
      "PerformanceService": "http://localhost:5003",
      "RecruitmentService": "http://localhost:5004",
      "AttendanceService": "http://localhost:5005",
      "PayrollService": "http://localhost:5006",
      "AnalyticsService": "http://localhost:5007",
      "NotificationService": "http://localhost:5008",
      "AuditService": "http://localhost:5009"
    },
    "RateLimit": {
      "Enabled": true,
      "RequestsPerMinute": 60,
      "RequestsPerHour": 1000,
      "HttpStatusCode": 429
    },
    "Authentication": {
      "JwtIssuer": "https://identityservice",
      "JwtAudience": "hranalytics",
      "JwtSecretKey": "your-super-secret-key-change-in-production",
      "ValidateToken": true,
      "PublicRoutes": [
        "/health",
        "/health/ready",
        "/swagger",
        "/identity/login",
        "/identity/register",
        "/identity/refresh-token"
      ]
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/identity/{**catch-all}"
        }
      },
      "employee": {
        "ClusterId": "employee",
        "Match": {
          "Path": "/employee/{**catch-all}"
        }
      },
      "performance": {
        "ClusterId": "performance",
        "Match": {
          "Path": "/performance/{**catch-all}"
        }
      },
      "recruitment": {
        "ClusterId": "recruitment",
        "Match": {
          "Path": "/recruitment/{**catch-all}"
        }
      },
      "attendance": {
        "ClusterId": "attendance",
        "Match": {
          "Path": "/attendance/{**catch-all}"
        }
      },
      "payroll": {
        "ClusterId": "payroll",
        "Match": {
          "Path": "/payroll/{**catch-all}"
        }
      },
      "analytics": {
        "ClusterId": "analytics",
        "Match": {
          "Path": "/analytics/{**catch-all}"
        }
      },
      "notification": {
        "ClusterId": "notification",
        "Match": {
          "Path": "/notification/{**catch-all}"
        }
      },
      "audit": {
        "ClusterId": "audit",
        "Match": {
          "Path": "/audit/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identity/localhost": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "employee": {
        "Destinations": {
          "employee/localhost": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "performance": {
        "Destinations": {
          "performance/localhost": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "recruitment": {
        "Destinations": {
          "recruitment/localhost": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "attendance": {
        "Destinations": {
          "attendance/localhost": {
            "Address": "http://localhost:5005"
          }
        }
      },
      "payroll": {
        "Destinations": {
          "payroll/localhost": {
            "Address": "http://localhost:5006"
          }
        }
      },
      "analytics": {
        "Destinations": {
          "analytics/localhost": {
            "Address": "http://localhost:5007"
          }
        }
      },
      "notification": {
        "Destinations": {
          "notification/localhost": {
            "Address": "http://localhost:5008"
          }
        }
      },
      "audit": {
        "Destinations": {
          "audit/localhost": {
            "Address": "http://localhost:5009"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
