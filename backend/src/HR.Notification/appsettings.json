{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=hr_notification;Username=hr_user;Password=hr_password123",
    "Redis": "localhost:6379"
  },
  "SendGrid": {
    "ApiKey": "SG.your-sendgrid-api-key-here",
    "FromEmail": "noreply@hrplatform.com"
  },
  "Twilio": {
    "AccountSid": "your-twilio-account-sid",
    "AuthToken": "your-twilio-auth-token",
    "FromPhoneNumber": "+1234567890"
  },
  "Firebase": {
    "CredentialsPath": "firebase-credentials.json"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "notification-service",
    "Topics": {
      "EmployeeEvents": "employee-events",
      "PerformanceEvents": "performance-events",
      "AttendanceEvents": "attendance-events",
      "PayrollEvents": "payroll-events",
      "RecruitmentEvents": "recruitment-events",
      "NotificationEvents": "notification-events",
      "DLQ": "dlq-failed-events"
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/notification-.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
