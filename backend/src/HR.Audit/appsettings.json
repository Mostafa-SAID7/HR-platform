{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "audit-service",
    "Topics": {
      "EmployeeEvents": "employee-events",
      "PerformanceEvents": "performance-events",
      "AttendanceEvents": "attendance-events",
      "PayrollEvents": "payroll-events",
      "RecruitmentEvents": "recruitment-events",
      "NotificationEvents": "notification-events",
      "DLQ": "dlq-failed-events"
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/audit-.txt",
          "rollingInterval": "Day"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
